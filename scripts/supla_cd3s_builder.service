[Unit]
Description=Supla CD3S local builder
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=langnet
Group=langnet
WorkingDirectory=/home/langnet/Projekty/Supla_CD3S
Environment=LOCAL_BUILDER_HOST=127.0.0.1
Environment=LOCAL_BUILDER_PORT=8182
Environment=PLATFORMIO_CMD=/home/langnet/.local/bin/platformio
ExecStart=/home/langnet/Projekty/Supla_CD3S/scripts/run_local_builder.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
